<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AIVoiceChanger"
        android:usesCleartextTraffic="true">

        <activity
            android:name="com.example.aivoicechangersounds.ui.main.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.example.aivoicechangersounds.ui.voiceai.VoiceAIActivity"
            android:exported="false"
            android:theme="@style/Theme.AIVoiceChanger.NoActionBar"
            android:parentActivityName="com.example.aivoicechangersounds.ui.main.MainActivity" />

        <activity
            android:name="com.example.aivoicechangersounds.ui.audioplayer.AudioPlayerActivity"
            android:exported="false"
            android:theme="@style/Theme.AIVoiceChanger.NoActionBar"
            android:parentActivityName="com.example.aivoicechangersounds.ui.voiceai.VoiceAIActivity" />

    </application>

</manifest>
