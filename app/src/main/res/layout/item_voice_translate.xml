<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/const1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/circleimg1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/avatarl2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:id="@+id/txtlang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="English (US)"
                android:textSize="14sp"
                android:layout_marginLeft="20dp"
                android:fontFamily="@font/outfitregular"
                android:textColor="@color/black"
                app:layout_constraintStart_toEndOf="@+id/circleimg1"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:id="@+id/txtspeak"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="hello assalamu alaikum"
                android:textSize="14sp"
                android:fontFamily="@font/outfitregular"
                android:textColor="@color/black"
                app:layout_constraintStart_toEndOf="@+id/circleimg1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/txtlang"
                android:layout_marginLeft="20dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/const2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/const1">
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/circleimg2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/agvatar3"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:id="@+id/txtlang2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spanish"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:fontFamily="@font/outfitregular"
                app:layout_constraintStart_toEndOf="@+id/circleimg2"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginLeft="20dp"/>
            <TextView
                android:id="@+id/txtoutput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Hola  assalamu alaikum"
                android:textSize="14sp"
                android:fontFamily="@font/outfitregular"
                android:textColor="@color/black"
                app:layout_constraintStart_toEndOf="@+id/circleimg2"
                app:layout_constraintTop_toBottomOf="@+id/txtlang2"
                app:layout_constraintEnd_toStartOf="@+id/triup"
                android:layout_marginLeft="20dp"/>
            <ImageButton
                android:id="@+id/triup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/triup"
                android:backgroundTint="@android:color/transparent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/const2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                android:id="@+id/copy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_copy"
                android:backgroundTint="@android:color/transparent"
                app:tint="@color/black"/>
            <ImageButton
                android:id="@+id/speak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_speak"
                android:backgroundTint="@android:color/transparent"/>
            <ImageButton
                android:id="@+id/share"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_sharing"
                android:backgroundTint="@android:color/transparent"/>
            <ImageButton
                android:id="@+id/delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_del"
                android:backgroundTint="@android:color/transparent"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>